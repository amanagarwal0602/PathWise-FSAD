{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/sample",
      "destination": "/sample/index.html"
    },
    {
      "source": "/sample/(.*)",
      "destination": "/sample/$1"
    },
    {
      "source": "/((?!sample).*)",
      "destination": "/index.html"
    }
  ]
}
